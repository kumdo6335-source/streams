rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomCode} {
      // 문서 ID(4자리 코드)를 아는 사람만 접근 가능. 전체 목록 조회(list)는 금지하여
      // 코드를 모르면 어떤 방이 존재하는지 알 수 없도록 한다. (로그인 없는 교실용 게임 전제)
      allow get: if true;
      allow list: if false;
      allow create, update: if true;
      allow delete: if false;

      match /players/{playerId} {
        // 이 서브컬렉션을 조회하려면 이미 상위 roomCode를 알아야 하므로 list 허용.
        allow get, list: if true;
        allow create, update: if true;
        allow delete: if false;
      }
    }
  }
}
